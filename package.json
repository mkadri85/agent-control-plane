{
  "name": "agent-control-plane",
  "version": "0.1.0",
  "description": "A minimal, framework-agnostic control plane for AI agent fleets: signal plane, confidence gate, and kill switch.",
  "type": "module",
  "license": "MIT",
  "author": "Mohamed Kadri",
  "keywords": [
    "ai-agents",
    "agentops",
    "observability",
    "sre",
    "llm",
    "kill-switch",
    "control-plane",
    "autonomous-agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mkadri85/agent-control-plane.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "demo": "tsx examples/demo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
